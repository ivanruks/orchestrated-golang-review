{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SubAgentReport",
  "description": "JSON output schema for go-review sub-agents",
  "type": "object",
  "required": ["agent", "files_checked", "findings", "positive"],
  "properties": {
    "agent": {
      "type": "string",
      "enum": ["correctness", "concurrency", "conventions", "style", "performance", "security", "consistency", "transactions", "tests"]
    },
    "files_checked": {
      "type": "integer",
      "minimum": 0
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "title", "file", "line", "category", "problem", "code_before", "code_after", "requires_verification"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(CORR|CONC|CONV|STYL|PERF|SEC|CONS|TXN|TEST)-[0-9]+$"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor"]
          },
          "title": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "category": { "type": "string" },
          "problem": { "type": "string" },
          "code_before": { "type": "string" },
          "code_after": { "type": "string" },
          "requires_verification": { "type": "boolean" }
        }
      }
    },
    "positive": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 5,
      "description": "Unresolved questions or risk areas the agent could not fully verify. Each item is either a question or a brief residual risk note. Only include when missing context or low confidence blocks a definitive assessment."
    }
  }
}
